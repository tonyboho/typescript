{
    "name": "ts-lazy-property",
    "version": "0.0.2",
    "description": "TypeScript program transformer that expands @lazy class properties before type checking.",
    "type": "module",
    "packageManager": "pnpm@11.7.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tonyboho/typescript.git",
        "directory": "packages/ts-lazy-property"
    },
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "default": "./dist/src/index.js"
        }
    },
    "files": [
        "dist/src",
        "README.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
        "pretest": "pnpm run build",
        "test": "siesta dist/tests",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "fixture": "pnpm --dir tests/fixture-suite run build && pnpm --dir tests/fixture-suite run test",
        "prepare": "ts-patch install"
    },
    "keywords": [
        "typescript",
        "transformer",
        "ts-patch",
        "lazy"
    ],
    "license": "MIT",
    "peerDependencies": {
        "typescript": "catalog:"
    },
    "devDependencies": {
        "@bryntum/siesta": "catalog:",
        "@types/node": "catalog:",
        "ts-patch": "catalog:",
        "typescript": "catalog:"
    }
}
