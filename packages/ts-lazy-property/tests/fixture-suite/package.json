{
    "name": "ts-lazy-property-fixture-suite",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.7.0",
    "scripts": {
        "build": "pnpm run build:standard && pnpm run build:legacy",
        "build:legacy": "tsc -p tsconfig.legacy.json",
        "build:standard": "tsc -p tsconfig.json",
        "test": "pnpm run test:standard && pnpm run test:legacy",
        "test:legacy": "siesta dist/legacy",
        "test:standard": "siesta dist/standard",
        "prepare": "ts-patch install"
    },
    "dependencies": {
        "ts-lazy-property": "workspace:*"
    },
    "devDependencies": {
        "@bryntum/siesta": "catalog:",
        "ts-patch": "catalog:",
        "typescript": "catalog:"
    }
}
