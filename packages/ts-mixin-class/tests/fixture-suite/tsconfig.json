{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "strict": true,
        "noUnusedLocals": true,
        "useDefineForClassFields": false,
        "skipLibCheck": true,
        "rootDir": "src",
        "outDir": "dist/standard",
        "declaration": true,
        "plugins": [
            {
                "transform": "ts-mixin-class",
                "transformProgram": true
            },
            {
                "name": "ts-mixin-class/language-service-plugin"
            }
        ],
        "experimentalDecorators": false
    },
    "include": [
        "src/**/*.ts"
    ]
}
