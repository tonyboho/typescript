{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "strict": true,
        "useDefineForClassFields": false,
        "skipLibCheck": true,
        "rootDir": "src",
        "plugins": [
            {
                "transform": "ts-lazy-property",
                "transformProgram": true
            }
        ]
    },
    "include": [
        "src/**/*.t.ts"
    ]
}
