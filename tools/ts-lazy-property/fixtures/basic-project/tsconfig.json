{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2022", "DOM"
        ],
        "strict": true,
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": "src",
        "plugins": [
            {
                "transform": "ts-lazy-property",
                "transformProgram": true
            }
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}
