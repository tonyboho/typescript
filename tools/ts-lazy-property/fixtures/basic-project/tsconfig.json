{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "strict": true,
        "useDefineForClassFields": false,
        "skipLibCheck": true,
        "outDir": "dist",
        "plugins": [
            {
                "transform": "ts-lazy-property",
                "transformProgram": true
            }
        ],
        "experimentalDecorators": false
    },
    "include": [
        "src/**/*.ts"
    ]
}
